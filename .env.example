# User/Group ID for container permissions
# Use your current user ID: id -u
# Use your current group ID: id -g
UID=1000
GID=1000

# PostgreSQL Configuration
# IMPORTANT: Change POSTGRES_PASSWORD to a strong, secure password
POSTGRES_DB=atuin
POSTGRES_USER=atuin
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# Atuin Server Configuration
# Set to "true" to allow open registration (not recommended for production)
ATUIN_OPEN_REGISTRATION=false
